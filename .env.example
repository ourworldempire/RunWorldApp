# RunWorld Flutter — Environment Variables
# Copy this file to .env and fill in your values

# Backend API (for Android emulator: 10.0.2.2 maps to your machine's localhost)
API_BASE_URL=http://10.0.2.2:5000/api

# For real device on same WiFi network, use your machine's local IP:
# API_BASE_URL=http://192.168.x.x:5000/api

# Google Maps (required for HomeScreen, RunSummaryScreen)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Google Sign-In (required for Google OAuth in SignUp/Login)
GOOGLE_CLIENT_ID=your_google_oauth_client_id
